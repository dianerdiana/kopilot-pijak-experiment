// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  SUPER_ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum StockUnit {
  ml
  gr
  pcs
}

enum PredictionType {
  REVENUE_FORECAST
  TRAFFIC_FORECAST
  DEMAND_FORECAST
  DEMAND_RECOMMENDATION
}

enum ProductCategory {
  Coffee    @map("KOPI")
  NonCoffee @map("NON_KOPI")
  Snack     @map("MAKANAN_RINGAN")
}

enum ProductVariant {
  Bottle @map("BOTOL")
  Cool   @map("DINGIN")
  Hot    @map("PANAS")
  Food   @map("MAKANAN")
}

enum ProductSize {
  Large         @map("BESAR")
  Regular       @map("REGULAR")
  Single        @map("SATUAN")
  BottleRegular @map("500ML")
  BottleLarge   @map("1000ML")
}

enum SupplierType {
  TraditionalMarket @map("PASAR_TRADISIONAL")
  IceSupplier       @map("PEMASOK_ES")
  GeneralSupplier   @map("PEMASOK_UMUM")
  LocalRoastery     @map("ROASTERY_LOKAL")
  PackagingStore    @map("TOKO_KEMASAN")
}

enum StorageType {
  Frozen                   @map("BEKU")
  Refrigerated             @map("DINGIN")
  RefrigeratedAfterOpening @map("DINGIN_SETELAH_DIBUKA")
  RoomTemperature          @map("SUHU_RUANG")
  Dry                      @map("KERING")
}

enum StockStatus {
  Sufficient @map("AMAN")
  Restock    @map("RESTOCK")
  Low        @map("ALERT")
  OutOfStock @map("HABIS")
}

// Models
model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String     @map("password_hash")
  role      UserRole
  status    UserStatus
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  @@map("users")
}

model Product {
  id        String          @id @default(uuid())
  productId String          @unique @map("product_id")
  name      String
  variant   ProductVariant
  category  ProductCategory
  size      ProductSize
  price     Decimal         @db.Decimal(10, 2)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  productIngredients ProductIngredient[]

  @@unique([variant, category, size])
  @@index([productId])
  @@map("products")
}

model ProductIngredient {
  id              String  @id @default(uuid())
  productId       String  @map("product_id")
  stockId         String  @map("stock_id")
  quantityPerUnit Decimal @map("quantity_per_unit") @db.Decimal(10, 3)

  product Product @relation(fields: [productId], references: [id])
  stock   Stock   @relation(fields: [stockId], references: [id])

  @@unique([productId, stockId])
  @@map("product_ingredients")
}

model RawMaterial {
  id                    String       @id @default(uuid())
  materialId            String       @unique @map("id_bahan")
  name                  String       @unique @map("nama_bahan")
  unit                  StockUnit    @map("satuan")
  pricePerUnit          Decimal      @map("biaya_per_satuan") @db.Decimal(10, 2)
  supplier              SupplierType @map("jenis_pemasok")
  unOpenedShelfLifeDays Int          @map("umur_simpan_belum_dibuka_hari") // in days
  openedShelfLifeDays   Int          @map("umur_simpan_sudah_dibuka_hari")
  storageType           StorageType  @map("jenis_penyimpanan")
  reorderPoint          Int          @map("reorder_point")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  stocks Stock[]

  @@map("raw_materials")
}

model Stock {
  id              String      @id @default(uuid())
  materialId      String
  currentQuantity Int         @map("current_quantity")
  minimumQuantity Int         @map("minimum_quantity")
  resilienceDays  Int         @map("ketahanan_hari")
  status          StockStatus @default(Sufficient)
  lastUpdated     DateTime    @map("last_updated")

  productIngredients  ProductIngredient[]
  rawMaterial         RawMaterial?         @relation(fields: [rawMaterialId], references: [id])
  rawMaterialId       String?
  dailyStockSnapshots DailyStockSnapshot[]

  @@map("stocks")
}

model StockReceipts {
  id                 String    @id @default(uuid())
  receiptId          String    @unique @map("id_penerimaan")
  materialId         String    @map("id_bahan")
  totalQuantity      Int       @map("jumlah_diterima")
  pricePerUnit       Decimal   @map("biaya_per_satuan") @db.Decimal(10, 2)
  receiptDate        DateTime  @map("tanggal_penerimaan") @db.Date
  supplierName       String    @map("nama_pemasok")
  batchId            String    @map("id_batch")
  remainingStock     Int       @map("sisa_stock_batch")
  openedDate         DateTime? @map("tanggal_dibuka") @db.Date
  expiryUnopenedDate DateTime? @map("tanggal_expired_belum_dibuka") @db.Date
  expiryOpenedDate   DateTime? @map("tanggal_expired_setelah_dibuka") @db.Date
  expiryDate         DateTime? @map("tanggal_expired_efektif") @db.Date

  @@map("stock_receipts")
}

model DailyStockSnapshot {
  id             String   @id @default(uuid())
  stockId        String   @map("stock_id")
  beginningStock Int      @map("stock_awal")
  stockIn        Int      @map("stock_masuk")
  usedStock      Int      @map("stock_terpakai")
  wastedStock    Int      @map("stock_terbuang")
  endingStock    Int      @map("stock_akhir")
  flagOutOfStock Boolean  @map("flag_stok_habis")
  flagNearExpiry Boolean  @map("flag_hampir_expired")
  snapshotDate   DateTime @map("tanggal_snapshot") @db.Date

  stock Stock @relation(fields: [stockId], references: [id])

  @@map("daily_stock_snapshots")
}

model Prediction {
  id                String         @id @default(uuid())
  storeId           String         @map("store_id")
  type              PredictionType
  cutoffDate        DateTime       @map("cutoff_date") @db.Date
  cutoffHour        Int?           @map("cutoff_hour")
  modelVersion      String         @map("model_version")
  responseData      Json           @map("response_data")
  normalizedSummary Json           @map("normalized_summary")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@unique([storeId, type, cutoffDate, cutoffHour])
  @@map("predictions")
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SuperAdmin @map("super_admin")
  Manager    @map("manager")
}

enum UserStatus {
  Active
  Inactive
}

enum StockUnit {
  ml
  gr  @map("gram")
  pcs
}

enum PredictionType {
  RevenueForecast @map("revenue_forecast")
  TrafficForecast @map("traffic_forecast")
  DemandForecast  @map("demand_forecast")
}

enum ProductCategory {
  Coffee    @map("kopi")
  NonCoffee @map("non_kopi")
  Snack     @map("makanan_ringan")
}

enum ProductVariant {
  Bottle @map("botolan")
  Cool   @map("dingin")
  Hot    @map("panas")
  Food   @map("makanan")
}

enum ProductSize {
  Large         @map("large")
  Regular       @map("regular")
  Single        @map("satuan")
  BottleRegular @map("500ml")
  BottleLarge   @map("1000ml")
}

enum SupplierType {
  TraditionalMarket @map("pasar_tradisional")
  IceSupplier       @map("pemasok_es")
  GeneralSupplier   @map("pemasok_umum")
  LocalRoastery     @map("roastery_lokal")
  PackagingStore    @map("toko_kemasan")
}

enum StorageType {
  Frozen                   @map("beku")
  Refrigerated             @map("dingin")
  RefrigeratedAfterOpening @map("dingin_setelah_dibuka")
  RoomTemperature          @map("suhu_ruang")
  Dry                      @map("kering")
}

enum StockStatus {
  Sufficient @map("aman")
  Restock    @map("restock")
  Low        @map("alert")
  OutOfStock @map("habis")
}

enum PaymentMethod {
  Cash    @map("tunai")
  NonCash @map("qris")
}

enum OrderType {
  DineIn   @map("makan_di_tempat")
  TakeAway @map("bawa_pulang")
  Delivery @map("pengantaran")
}

enum SalesChannel {
  Offline       @map("offline")
  Online        @map("online")
  OfflineOnline @map("offline_online")
}

enum CustomerSegment {
  TeacherWorker    @map("dosen_staf")
  Student          @map("mahasiswa")
  LocalWorker      @map("pekerja_sekitar")
  DeliveryCustomer @map("pelanggan_delivery")
  LocalResident    @map("warga_sekitar")
}

enum DiscountType {
  Event         @map("acara")
  Bundling      @map("bundling")
  Payday        @map("gajian")
  DeliveryPromo @map("promo_pengantaran")
  None          @map("tidak_ada")
}

enum PromoStatus {
  Active    @map("aktif")
  Inactive  @map("tidak_aktif")
  Upcoming  @map("akan_datang")
  Completed @map("selesai")
}

enum NotificationType {
  PeakHourAlert @map("peringatan_jam_sibuk")
  StockAlert    @map("peringatan_stok")
  Report        @map("laporan")
}

enum NotificationChannel {
  WebApp @map("web_app")
  Email  @map("email")
  Both   @map("both")
}

enum NotificationPriority {
  Low    @map("rendah")
  Medium @map("sedang")
  High   @map("tinggi")
}

enum NotificationStatus {
  Active   @map("aktif")
  Expired  @map("kedaluwarsa")
  Resolved @map("selesai")
  Archived @map("diarsipkan")
}

enum WeatherCondition {
  Sunny     @map("cerah")
  Cloudy    @map("berawan")
  LightRain @map("hujan_ringan")
  HeavyRain @map("hujan_deras")
}

enum RamadhanPeriod {
  None       @map("tidak_ada")
  FastingDay @map("siang_puasa")
  IftarPeak  @map("puncak_buka_puasa")
  AfterIftar @map("setelah_buka_puasa")
}

enum EventType {
  None             @map("tidak_ada")
  LocalEvent       @map("acara_lokal")
  NationalHoliday  @map("libur_nasional")
  ReligiousHoliday @map("libur_keagamaan")
  ReligiousPeriod  @map("periode_keagamaan")
}

model User {
  id                String             @id @default(uuid())
  userId            String             @unique @map("id_user")
  name              String
  email             String             @unique
  password          String             @map("password_hash")
  role              UserRole
  status            UserStatus
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  notificationReads NotificationRead[]

  @@map("users")
}

model Product {
  id        String          @id @default(uuid())
  productId String          @unique @map("id_produk")
  name      String          @map("nama_produk")
  variant   ProductVariant  @map("varian")
  category  ProductCategory @map("kategori")
  size      ProductSize     @map("ukuran")
  price     Decimal         @map("harga_dasar") @db.Decimal(10, 2)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  productIngredients ProductIngredient[]
  transactionDetails TransactionDetail[]

  @@unique([variant, category, size])
  @@index([productId])
  @@map("produk")
}

model ProductIngredient {
  id              String  @id @default(uuid())
  productId       String  @map("id_produk")
  materialId      String  @map("id_bahan")
  quantityPerUnit Decimal @map("jumlah_dibutuhkan") @db.Decimal(10, 3)

  product     Product     @relation(fields: [productId], references: [productId])
  rawMaterial RawMaterial @relation(fields: [materialId], references: [materialId])

  @@unique([productId, materialId])
  @@index([materialId])
  @@map("resep_produk")
}

model RawMaterial {
  id                    String       @id @default(uuid())
  materialId            String       @unique @map("id_bahan")
  name                  String       @unique @map("nama_bahan")
  unit                  StockUnit    @map("satuan")
  pricePerUnit          Decimal      @map("biaya_per_satuan") @db.Decimal(10, 2)
  supplier              SupplierType @map("jenis_pemasok")
  unOpenedShelfLifeDays Int          @map("umur_simpan_belum_dibuka_hari")
  openedShelfLifeDays   Int          @map("umur_simpan_setelah_dibuka_hari")
  storageType           StorageType  @map("jenis_penyimpanan")
  reorderPoint          Int          @map("titik_pemesanan_ulang")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  stocks              Stock[]
  stockReceipts       StockReceipt[]
  productIngredients  ProductIngredient[]
  dailyStockSnapshots DailyStockSnapshot[]

  @@map("bahan_baku")
}

model Stock {
  id              String      @id @default(uuid())
  stockId         String      @unique @map("id_stok")
  materialId      String      @map("id_bahan")
  currentQuantity Int         @map("current_quantity")
  minimumQuantity Int         @map("minimum_quantity")
  resilienceDays  Int         @map("ketahanan_hari")
  status          StockStatus @default(Sufficient)
  lastUpdated     DateTime    @map("last_updated")

  rawMaterial RawMaterial @relation(fields: [materialId], references: [materialId])

  @@index([materialId])
  @@map("stocks")
}

model StockReceipt {
  id                 String    @id @default(uuid())
  receiptId          String    @unique @map("id_penerimaan")
  materialId         String    @map("id_bahan")
  receivedQuantity   Decimal   @map("jumlah_diterima") @db.Decimal(12, 3)
  pricePerUnit       Decimal   @map("biaya_per_satuan") @db.Decimal(12, 3)
  receiptDate        DateTime  @map("tanggal_penerimaan") @db.Date
  supplierName       String    @map("nama_pemasok")
  batchId            String    @map("id_batch")
  openedDate         DateTime? @map("tanggal_dibuka") @db.Date
  expiryUnopenedDate DateTime? @map("tanggal_expired_belum_dibuka") @db.Date
  expiryOpenedDate   DateTime? @map("tanggal_expired_setelah_dibuka") @db.Date
  expiryDate         DateTime? @map("tanggal_expired_efektif") @db.Date

  rawMaterial RawMaterial @relation(fields: [materialId], references: [materialId])

  @@index([materialId])
  @@index([receiptDate])
  @@map("penerimaan_stok")
}

model DailyStockSnapshot {
  id             String   @id @default(uuid())
  materialId     String   @map("id_bahan")
  beginningStock Decimal  @map("stok_awal") @db.Decimal(12, 3)
  stockIn        Decimal  @map("stok_masuk") @db.Decimal(12, 3)
  usedStock      Decimal  @map("stok_terpakai") @db.Decimal(12, 3)
  wastedStock    Decimal  @map("stok_terbuang") @db.Decimal(12, 3)
  endingStock    Decimal  @map("stok_akhir") @db.Decimal(12, 3)
  flagOutOfStock Boolean  @map("flag_stok_habis")
  flagNearExpiry Boolean  @map("flag_hampir_expired")
  snapshotDate   DateTime @map("tanggal") @db.Date

  rawMaterial RawMaterial @relation(fields: [materialId], references: [materialId])

  @@unique([snapshotDate, materialId])
  @@index([materialId])
  @@map("snapshot_stok_harian")
}

model Order {
  id                       String          @id @default(uuid())
  orderId                  String          @unique @map("id_pesanan")
  orderTime                DateTime        @map("waktu_pesanan")
  paymentMethod            PaymentMethod   @map("metode_pembayaran")
  orderType                OrderType       @map("jenis_pesanan")
  salesChannel             SalesChannel    @map("kanal_penjualan")
  estimatedCustomerSegment CustomerSegment @map("segmen_pelanggan_estimasi")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  transactionDetails TransactionDetail[]

  @@index([orderTime])
  @@map("pesanan")
}

model TransactionDetail {
  id              String       @id @default(uuid())
  transactionId   String       @unique @map("id_transaksi")
  orderId         String       @map("id_pesanan")
  productId       String       @map("id_produk")
  quantity        Int          @map("jumlah")
  price           Decimal      @map("harga_satuan") @db.Decimal(12, 2)
  discount        Decimal      @map("jumlah_diskon") @db.Decimal(12, 2)
  discountApplied Boolean      @default(false) @map("diskon_diterapkan")
  discountType    DiscountType @default(None) @map("jenis_diskon")
  totalPrice      Decimal      @map("total_harga") @db.Decimal(12, 2)
  promotionId     String       @default("tidak_ada") @map("id_promo")

  order   Order   @relation(fields: [orderId], references: [orderId])
  product Product @relation(fields: [productId], references: [productId])

  @@index([orderId])
  @@index([productId])
  @@index([promotionId])
  @@map("detail_transaksi")
}

model Prediction {
  id                String         @id @default(uuid())
  type              PredictionType
  cutoffDate        DateTime       @map("cutoff_date") @db.Date
  cutoffHour        Int?           @map("cutoff_hour")
  forecastDays      Int            @map("forecast_days")
  modelVersion      String         @map("model_version")
  responseData      Json           @map("response_data")
  normalizedSummary Json           @map("normalized_summary")
  generatedAt       DateTime       @default(now()) @map("generated_at")

  @@index([type, cutoffDate])
  @@map("predictions")
}

model WeatherContext {
  id             Int              @id @default(autoincrement())
  dateTime       DateTime         @unique @map("waktu_jam")
  condition      WeatherCondition @map("kondisi_cuaca")
  ramadhanPeriod RamadhanPeriod   @default(None) @map("periode_ramadan")

  @@map("konteks_jam")
}

model DailyContext {
  id                Int       @id @default(autoincrement())
  date              DateTime  @default(now()) @map("tanggal") @db.Date
  isHoliday         Boolean   @map("apakah_libur")
  isWeekend         Boolean   @map("apakah_akhir_pekan")
  isRamadhanPeriode Boolean   @map("apakah_ramadan")
  isPaydayPeriode   Boolean   @map("apakah_periode_gajian")
  eventName         String    @default("tidak_ada") @map("nama_event")
  eventType         EventType @default(None) @map("jenis_event")

  @@map("konteks_harian")
}

model Notification {
  id         String               @id @default(uuid())
  storeId    String               @map("store_id")
  type       NotificationType
  title      String
  message    String
  payload    Json
  channel    NotificationChannel
  priority   NotificationPriority
  status     NotificationStatus
  validUntil DateTime             @map("valid_until")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  notificationReads NotificationRead[]

  @@index([status, validUntil])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  userId         String   @map("user_id")
  readAt         DateTime @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}

model PromoCampaigns {
  id             String       @id @default(uuid())
  promoId        String       @unique @map("id_promo")
  name           String       @map("nama_promo")
  startDate      DateTime     @map("tanggal_mulai") @db.Date
  endDate        DateTime     @map("tanggal_selesai") @db.Date
  discountType   DiscountType @map("jenis_diskon")
  idProducts     String       @map("id_produk_target")
  categoryTarget String       @map("kategori_target")
  discountValue  Decimal      @map("nilai_diskon") @db.Decimal(10, 2)
  salesChannel   SalesChannel @map("kanal_penjualan")
  minimumUnit    String       @map("minimal_pembelian")
  status         PromoStatus  @map("status_promo")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([startDate, endDate])
  @@map("kampanye_promo")
}
